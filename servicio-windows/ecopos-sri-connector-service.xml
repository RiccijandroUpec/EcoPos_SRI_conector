<service>
  <id>ecopos-sri-connector</id>
  <name>EcoPos SRI Connector</name>
  <description>Facturacion electronica SRI para EcoPos: firma, envia y consulta comprobantes ante el SRI (Ecuador) en segundo plano.</description>

  <!-- "java" a secas (no una ruta fija a JAVA_HOME) para que funcione en
       cualquier maquina donde el instalador de Java haya agregado java.exe
       al PATH del sistema - que es el caso normal. Si en una maquina en
       particular java no esta en el PATH, cambiar esto a la ruta completa
       (ej. C:\Program Files\Eclipse Adoptium\jdk-11...\bin\java.exe). -->
  <executable>java</executable>
  <arguments>-cp ecopos-sri-connector.jar com.openbravo.pos.sri.ConectorPrincipal</arguments>

  <!-- %BASE% = la carpeta donde esta este mismo archivo .xml (y el .exe del
       servicio) - por eso el jar, config/, pendientes/ y este servicio deben
       vivir siempre juntos en la misma carpeta (sri-conector/), sin importar
       en que ruta este instalado EcoPos en cada maquina. -->
  <workingdirectory>%BASE%</workingdirectory>
  <logpath>%BASE%\logs</logpath>
  <log mode="roll-by-size">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>8</keepFiles>
  </log>

  <!-- Si el proceso se cae solo (ej. por una excepcion no capturada), que
       Windows lo reinicie solo en vez de dejarlo caido silenciosamente. -->
  <onfailure action="restart" delay="10 sec"/>
  <onfailure action="restart" delay="30 sec"/>
  <resetfailure>1 hour</resetfailure>

  <startmode>Automatic</startmode>
  <stoptimeout>15 sec</stoptimeout>
</service>
